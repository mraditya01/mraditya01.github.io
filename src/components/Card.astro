---
export interface Props {
  title: string;
  subtitle?: string;
  img?: string;
  desc: string;
  url?: string;
  badge?: string;
}

const { title, subtitle, img, desc, url, badge } = Astro.props;
---

<div class="card-base">
  {badge && <div class="badge badge-primary mb-2">{badge}</div>}
  {img && <img src={img} alt={title} class="w-full rounded-lg mb-4 h-48 object-cover" />}
  <h3 class="text-xl font-bold mb-2">{title}</h3>
  {subtitle && <p class="text-neutral-400 text-sm mb-2">{subtitle}</p>}
  <p class="text-neutral-300 mb-4 text-sm leading-relaxed">{desc}</p>
  {url && (
    <a href={url} target="_blank" rel="noopener" class="btn-primary text-sm inline-block">
      Learn More →
    </a>
  )}
</div>
