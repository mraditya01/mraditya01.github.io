---
export interface Props {
  title: string;
  img?: string;
  desc: string;
  url?: string;
  badge?: string;
  tags?: string[];
  target?: string;
}

const { title, img, desc, url, badge, tags, target = '_self' } = Astro.props;
---

<div class="card-base flex flex-col md:flex-row gap-6">
  {img && (
    <div class="flex-shrink-0 md:w-48">
      <img src={img} alt={title} class="w-full rounded-lg h-48 object-cover" />
    </div>
  )}
  
  <div class="flex-1">
    {badge && <div class="badge badge-primary mb-2">{badge}</div>}
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-neutral-300 mb-4">{desc}</p>
    
    {tags && (
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span class="badge badge-outline badge-sm">{tag}</span>
        ))}
      </div>
    )}
    
    {url && (
      <a href={url} target={target} rel="noopener" class="btn-primary text-sm inline-block">
        View Project →
      </a>
    )}
  </div>
</div>
